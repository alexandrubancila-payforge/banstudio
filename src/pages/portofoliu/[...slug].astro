---
import BaseLayout from '@layouts/BaseLayout.astro';
import Button from '@components/ui/Button.astro';
import Badge from '@components/ui/Badge.astro';
import SchemaBreadcrumb from '@components/seo/SchemaBreadcrumb.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('portofoliu');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<BaseLayout
  title={project.data.title}
  description={project.data.description}
  ogImage={project.data.image}
>
  <SchemaBreadcrumb items={[
    { name: 'Acasă', href: '/' },
    { name: 'Portofoliu', href: '/portofoliu' },
    { name: project.data.title, href: `/portofoliu/${project.id}` },
  ]} />
  <article class="py-section">
    <div class="container">
      <!-- Breadcrumb -->
      <nav class="mb-8 text-sm text-neutral-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-neutral-600">Acasă</a>
        <span class="mx-2">/</span>
        <a href="/portofoliu" class="hover:text-neutral-600">Portofoliu</a>
        <span class="mx-2">/</span>
        <span class="text-neutral-600">{project.data.title}</span>
      </nav>

      <!-- Header -->
      <div class="max-w-3xl">
        <div class="flex flex-wrap gap-2">
          {project.data.tags.map((tag) => (
            <Badge variant="primary">{tag}</Badge>
          ))}
        </div>
        <h1 class="mt-4 text-display font-heading font-black text-neutral-950">
          {project.data.title}
        </h1>
        <p class="mt-4 text-lg text-neutral-500 sm:text-xl">
          {project.data.description}
        </p>
        <dl class="mt-6 flex flex-wrap gap-x-8 gap-y-3 text-sm">
          <div>
            <dt class="font-medium text-neutral-400">Client</dt>
            <dd class="text-neutral-700">{project.data.client}</dd>
          </div>
          <div>
            <dt class="font-medium text-neutral-400">An</dt>
            <dd class="text-neutral-700">{project.data.date.getFullYear()}</dd>
          </div>
          {project.data.url && (
            <div>
              <dt class="font-medium text-neutral-400">Site live</dt>
              <dd>
                <a
                  href={project.data.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-primary-600 hover:underline"
                >
                  Vizitează →
                </a>
              </dd>
            </div>
          )}
        </dl>
      </div>

      <!-- Imagine principală -->
      <div class="mt-10 overflow-hidden rounded-xl border border-neutral-200 bg-neutral-100">
        <img
          src={project.data.image}
          alt={project.data.imageAlt}
          class="w-full object-cover"
          loading="eager"
          decoding="async"
        />
      </div>

      <!-- Conținut studiu de caz -->
      <div class="prose mx-auto mt-12 max-w-3xl">
        <Content />
      </div>

      <!-- Navigare -->
      <div class="mt-16 flex flex-wrap justify-center gap-4 border-t border-neutral-200 pt-10">
        <Button href="/portofoliu" variant="secondary">
          ← Toate proiectele
        </Button>
        <Button href="/contact" variant="primary">
          Ai un proiect similar? Contactează-mă
        </Button>
      </div>
    </div>
  </article>
</BaseLayout>
