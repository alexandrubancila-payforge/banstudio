---
import BaseLayout from '@layouts/BaseLayout.astro';
---

<BaseLayout title="Home">
  <section class="container py-section">
    <h1 class="text-display font-heading font-black text-neutral-950">
      Ban Studio
    </h1>
    <p class="mt-4 max-w-2xl text-lg text-neutral-600">
      Creare site-uri web profesionale în Chișinău și București.
    </p>
    <div class="mt-8 flex flex-wrap gap-3 sm:gap-4">
      <a
        href="/contact"
        class="inline-flex items-center whitespace-nowrap rounded-lg bg-primary-600 px-5 py-3 text-sm font-medium text-white transition-colors hover:bg-primary-700 sm:px-6 sm:text-base"
      >
        Solicită o ofertă
      </a>
      <a
        href="/portofoliu"
        class="inline-flex items-center whitespace-nowrap rounded-lg border border-neutral-300 px-5 py-3 text-sm font-medium text-neutral-700 transition-colors hover:bg-neutral-100 sm:px-6 sm:text-base"
      >
        Vezi portofoliul
      </a>
    </div>
  </section>
</BaseLayout>
