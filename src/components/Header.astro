---
import { resolveLocale, getNavLinks, getAlternatePath, getDict } from '@/i18n';

const locale = resolveLocale(Astro.currentLocale);
const navLinks = getNavLinks(locale);
const dict = getDict(locale);
const currentPath = Astro.url.pathname;

const altLocale = locale === 'ro' ? 'ru' : 'ro';
const altPath = getAlternatePath(currentPath, altLocale);
const altLabel = altLocale.toUpperCase();
const contactHref = locale === 'ru' ? '/ru/kontakt' : '/contact';
---

<header class="fixed top-0 z-50 w-full border-b border-neutral-200/60 bg-white/80 backdrop-blur-lg">
  <div class="container flex h-16 items-center justify-between md:h-18">
    <!-- Logo -->
    <a href={locale === 'ru' ? '/ru' : '/'} class="font-heading text-xl font-black tracking-tight text-neutral-950">
      Ban Studio
    </a>

    <!-- Navigare desktop -->
    <nav class="hidden items-center gap-1 md:flex" aria-label={locale === 'ru' ? 'Основная навигация' : 'Navigare principala'}>
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'rounded-md px-3 py-2 text-sm font-medium transition-colors',
            currentPath.startsWith(link.href)
              ? 'text-primary-600'
              : 'text-neutral-600 hover:text-neutral-950',
          ]}
          aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}

      <!-- Language switcher -->
      <a
        href={altPath}
        class="rounded-md px-2.5 py-1.5 text-xs font-semibold text-neutral-400 transition-colors hover:text-neutral-950"
      >
        {altLabel}
      </a>

      <a
        href={contactHref}
        class="ml-2 inline-flex items-center rounded-lg bg-primary-600 px-4 py-2 text-sm font-medium text-white transition-colors hover:bg-primary-700"
      >
        {dict.nav.cta}
      </a>
    </nav>

    <!-- Mobile: lang switch + hamburger -->
    <div class="flex items-center gap-2 md:hidden">
      <a href={altPath} class="rounded-md px-2 py-1.5 text-xs font-semibold text-neutral-400 hover:text-neutral-950">
        {altLabel}
      </a>
      <button
        type="button"
        id="menu-toggle"
        class="flex size-10 items-center justify-center rounded-lg text-neutral-700 transition-colors hover:bg-neutral-100"
        aria-label={dict.header.menuOpen}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="icon-open" class="size-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 9h16.5m-16.5 6.75h16.5" />
        </svg>
        <svg id="icon-close" class="hidden size-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Meniu mobil -->
  <nav id="mobile-menu" class="hidden border-t border-neutral-200/60 bg-white md:hidden">
    <div class="container flex flex-col gap-1 py-4">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            'rounded-lg px-3 py-2.5 text-base font-medium transition-colors',
            currentPath.startsWith(link.href)
              ? 'bg-primary-50 text-primary-700'
              : 'text-neutral-700 hover:bg-neutral-50',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href={contactHref}
        class="mt-2 inline-flex items-center justify-center rounded-lg bg-primary-600 px-4 py-2.5 text-base font-medium text-white transition-colors hover:bg-primary-700"
      >
        {dict.nav.cta}
      </a>
    </div>
  </nav>
</header>

<div class="h-16 md:h-18" aria-hidden="true"></div>

<script>
  const toggle = document.getElementById('menu-toggle')!;
  const menu = document.getElementById('mobile-menu')!;
  const iconOpen = document.getElementById('icon-open')!;
  const iconClose = document.getElementById('icon-close')!;

  toggle.addEventListener('click', () => {
    const isOpen = menu.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(!isOpen));
    iconOpen.classList.toggle('hidden');
    iconClose.classList.toggle('hidden');
  });
</script>
