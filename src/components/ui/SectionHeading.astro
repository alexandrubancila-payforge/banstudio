---
interface Props {
  title: string;
  subtitle?: string;
  align?: 'left' | 'center';
  as?: 'h1' | 'h2' | 'h3';
}

const { title, subtitle, align = 'left', as: Tag = 'h2' } = Astro.props;
---

<div class:list={['max-w-2xl', align === 'center' && 'mx-auto text-center']}>
  <Tag class="text-headline font-heading font-black text-neutral-950">
    {title}
  </Tag>
  {subtitle && (
    <p class="mt-3 text-lg text-neutral-500 sm:mt-4 sm:text-xl">
      {subtitle}
    </p>
  )}
</div>
