---
import type { HTMLAttributes } from 'astro/types';

interface Props extends HTMLAttributes<'section'> {
  background?: 'white' | 'muted';
}

const { background = 'white', class: className, ...rest } = Astro.props;

const backgrounds = {
  white: '',
  muted: 'bg-neutral-50',
} as const;
---

<section
  class:list={['py-section', backgrounds[background], className]}
  {...rest}
>
  <div class="container">
    <slot />
  </div>
</section>
