---
interface Props {
  title: string;
  description: string;
  href: string;
  icon?: string;
}

const { title, description, href } = Astro.props;
---

<a
  href={href}
  class="group flex flex-col rounded-xl border border-neutral-200 bg-white p-5 transition-all duration-300 hover:border-primary-200 hover:shadow-medium sm:p-6"
>
  <span class="flex size-11 items-center justify-center rounded-lg bg-primary-100" aria-hidden="true">
    <svg class="size-5 text-primary-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
    </svg>
  </span>
  <h3 class="mt-4 font-heading text-lg font-bold text-neutral-950 group-hover:text-primary-700">
    {title}
  </h3>
  <p class="mt-2 text-sm leading-relaxed text-neutral-500">
    {description}
  </p>
  <span class="mt-auto pt-4 text-sm font-medium text-primary-600 group-hover:underline">
    Află mai multe →
  </span>
</a>
