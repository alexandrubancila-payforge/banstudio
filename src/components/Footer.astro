---
import { NAV_LINKS, SITE, SOCIAL_LINKS } from '@lib/constants';

const year = new Date().getFullYear();
---

<footer class="border-t border-neutral-200 bg-neutral-50">
  <div class="container py-12 md:py-16">
    <div class="grid gap-10 md:grid-cols-3">
      <!-- Brand -->
      <div>
        <a href="/" class="font-heading text-xl font-black tracking-tight text-neutral-950">
          {SITE.name}
        </a>
        <p class="mt-3 max-w-xs text-sm text-neutral-500">
          Site-uri web profesionale pentru afaceri din Moldova și România. Design modern, cod curat, rezultate măsurabile.
        </p>
      </div>

      <!-- Navigare -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-neutral-400">Pagini</h3>
        <nav class="mt-4 flex flex-col gap-2" aria-label="Footer">
          {NAV_LINKS.map((link) => (
            <a
              href={link.href}
              class="text-sm text-neutral-600 transition-colors hover:text-neutral-950"
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <!-- Contact rapid -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-neutral-400">Contact</h3>
        <div class="mt-4 flex flex-col gap-2 text-sm text-neutral-600">
          <a href="mailto:sasa.bancila@gmail.com" class="transition-colors hover:text-neutral-950">
            sasa.bancila@gmail.com
          </a>
          <a href="tel:+37369456448" class="transition-colors hover:text-neutral-950">
            069 456 448
          </a>
          <p>Chișinău, Moldova</p>
        </div>

        <!-- Social & messengers -->
        <div class="mt-6 flex flex-wrap gap-2">
          <a href="https://t.me/bancilaalexandru" target="_blank" rel="noopener noreferrer" class="flex size-9 items-center justify-center rounded-lg text-neutral-500 transition-colors hover:bg-neutral-200 hover:text-neutral-700" aria-label="Telegram">
            <svg class="size-5" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
          </a>
          <a href="https://wa.me/37369456448" target="_blank" rel="noopener noreferrer" class="flex size-9 items-center justify-center rounded-lg text-neutral-500 transition-colors hover:bg-neutral-200 hover:text-neutral-700" aria-label="WhatsApp">
            <svg class="size-5" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
          </a>
          {SOCIAL_LINKS.github && (
            <a href={SOCIAL_LINKS.github} target="_blank" rel="noopener noreferrer" class="flex size-9 items-center justify-center rounded-lg text-neutral-500 transition-colors hover:bg-neutral-200 hover:text-neutral-700" aria-label="GitHub">
              <svg class="size-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0 1 12 6.844a9.59 9.59 0 0 1 2.504.337c1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0 0 22 12.017C22 6.484 17.522 2 12 2Z"/></svg>
            </a>
          )}
          {SOCIAL_LINKS.linkedin && (
            <a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener noreferrer" class="flex size-9 items-center justify-center rounded-lg text-neutral-500 transition-colors hover:bg-neutral-200 hover:text-neutral-700" aria-label="LinkedIn">
              <svg class="size-5" fill="currentColor" viewBox="0 0 24 24"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286ZM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065Zm1.782 13.019H3.555V9h3.564v11.452ZM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003Z"/></svg>
            </a>
          )}
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-10 border-t border-neutral-200 pt-6 text-center text-sm text-neutral-400">
      <p>&copy; {year} {SITE.name}. Toate drepturile rezervate.</p>
    </div>
  </div>
</footer>
