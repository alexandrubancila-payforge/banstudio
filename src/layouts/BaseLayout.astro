---
import '@/styles/global.css';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import { resolveLocale, getSiteConfig, getAlternatePath } from '@/i18n';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  noindex?: boolean;
}

const locale = resolveLocale(Astro.currentLocale);
const site = getSiteConfig(locale);

const {
  title,
  description = site.description,
  ogImage = '/og-default.png',
  noindex = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, site.url);
const fullTitle = title === 'Home' ? `${site.name} — ${description}` : `${title} | ${site.name}`;

// Hreflang alternate URLs
const currentPath = Astro.url.pathname;
const roPath = locale === 'ro' ? currentPath : getAlternatePath(currentPath, 'ro');
const ruPath = locale === 'ru' ? currentPath : getAlternatePath(currentPath, 'ru');
const roURL = new URL(roPath, site.url);
const ruURL = new URL(ruPath, site.url);
---

<!doctype html>
<html lang={site.language}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- SEO -->
    <meta name="msvalidate.01" content="2D2B9DE7912774378FBD3360724A8AF5" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <!-- Hreflang -->
    <link rel="alternate" hreflang="ro" href={roURL} />
    <link rel="alternate" hreflang="ru" href={ruURL} />
    <link rel="alternate" hreflang="x-default" href={roURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, site.url)} />
    <meta property="og:locale" content={site.locale} />
    <meta property="og:site_name" content={site.name} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, site.url)} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Generator -->
    <meta name="generator" content={Astro.generator} />

    <slot name="head" />
  </head>
  <body class="min-h-dvh flex flex-col antialiased">
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
