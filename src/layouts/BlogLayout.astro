---
import BaseLayout from '@layouts/BaseLayout.astro';
import Badge from '@components/ui/Badge.astro';
import Button from '@components/ui/Button.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  updated?: Date;
  tags?: string[];
  image?: string;
  imageAlt?: string;
}

const { title, description, date, updated, tags = [], image, imageAlt } = Astro.props;

const formatDate = (d: Date) =>
  d.toLocaleDateString('ro-RO', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={title} description={description} ogImage={image}>
  <article class="py-section">
    <div class="container">
      <nav class="mb-8 text-sm text-neutral-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-neutral-600">Acasă</a>
        <span class="mx-2">/</span>
        <a href="/blog" class="hover:text-neutral-600">Blog</a>
        <span class="mx-2">/</span>
        <span class="text-neutral-600">{title}</span>
      </nav>

      <div class="mx-auto max-w-3xl">
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2">
            {tags.map((tag) => (
              <Badge variant="primary">{tag}</Badge>
            ))}
          </div>
        )}

        <h1 class="mt-4 text-display font-heading font-black text-neutral-950">
          {title}
        </h1>

        <p class="mt-4 text-lg text-neutral-500">
          {description}
        </p>

        <div class="mt-6 flex items-center gap-4 text-sm text-neutral-400">
          <time datetime={date.toISOString()}>
            {formatDate(date)}
          </time>
          {updated && (
            <span>
              · Actualizat <time datetime={updated.toISOString()}>{formatDate(updated)}</time>
            </span>
          )}
        </div>

        {image && (
          <div class="mt-8 overflow-hidden rounded-xl">
            <img
              src={image}
              alt={imageAlt || title}
              class="w-full object-cover"
            />
          </div>
        )}

        <div class="prose mt-10">
          <slot />
        </div>

        <div class="mt-16 border-t border-neutral-200 pt-8">
          <div class="rounded-xl bg-primary-50 p-6 text-center sm:p-8">
            <h2 class="font-heading text-xl font-bold text-neutral-950">
              Ai nevoie de un site profesional?
            </h2>
            <p class="mt-2 text-sm text-neutral-600">
              Contactează-mă pentru o consultanță gratuită despre proiectul tău.
            </p>
            <div class="mt-4">
              <Button href="/contact" variant="primary">
                Contactează-mă
              </Button>
            </div>
          </div>
        </div>

        <div class="mt-8 text-center">
          <Button href="/blog" variant="ghost">
            ← Toate articolele
          </Button>
        </div>
      </div>
    </div>
  </article>
</BaseLayout>
